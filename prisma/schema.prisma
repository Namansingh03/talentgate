generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CompanyRole {
  ADMIN
  RECRUITER
}

enum CompanySize {
  STARTUP
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum ExperienceLevel {
  INTERN
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum JobCategory {
  ENGINEERING
  DESIGN
  MARKETING
  SALES
  FINANCE
  HR
  OPERATIONS
  PRODUCT
  DATA
  DEVOPS
  OTHER
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  ACCEPTED
  REJECTED
}

enum JobStatus {
  DRAFT
  ACTIVE
  CLOSED
  EXPIRED
}

model User {
  id            String  @id
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?

  username        String? @unique
  displayUsername String?

  bio      String? @db.Text
  headline String?
  location String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  candidateProfile CandidateProfile?
  memberships      CompanyMember[]
  sessions         Session[]
  accounts         Account[]
  upgradeRequests  RecruiterUpgradeRequest[] @relation("UpgradeRequests")
  reviewedRequests RecruiterUpgradeRequest[] @relation("ReviewedRequests")
  savedJobs        SavedJob[]

  @@map("user")
}

model CandidateProfile {
  id     String @id @default(cuid())
  userId String @unique

  about String? @db.Text

  resumeUrl    String?
  portfolioUrl String?
  linkedinUrl  String?
  githubUrl    String?

  bannerImage  String?
  skills       String[]
  isOpenToWork Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  education    Education[]
  experience   WorkExperience[]
  applications Application[]

  @@index([userId])
}

model Education {
  id        String @id @default(cuid())
  profileId String

  school String
  degree String
  field  String

  startDate DateTime
  endDate   DateTime?
  isCurrent Boolean   @default(false)

  profile CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model WorkExperience {
  id        String @id @default(cuid())
  profileId String

  company  String
  title    String
  location String?

  startDate DateTime
  endDate   DateTime?
  isCurrent Boolean   @default(false)

  description String? @db.Text

  profile CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Company {
  id   String @id @default(cuid())
  name String
  slug String @unique

  logo        String?
  banner      String?
  website     String?
  linkedin    String?
  description Json?

  industry String?
  size     CompanySize @default(SMALL)
  location String?

  isVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  members                  CompanyMember[]
  recruiterUpgradeRequests RecruiterUpgradeRequest[]
  jobs                     Job[]

  @@index([slug])
}

model CompanyMember {
  id        String @id @default(cuid())
  userId    String
  companyId String

  role CompanyRole @default(RECRUITER)

  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}

model RecruiterUpgradeRequest {
  id     String        @id @default(cuid())
  status RequestStatus @default(PENDING)

  userId String
  user   User   @relation("UpgradeRequests", fields: [userId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  reviewedById String?
  reviewedBy   User?   @relation("ReviewedRequests", fields: [reviewedById], references: [id], onDelete: SetNull)

  rejectionNote String?
  requestedAt   DateTime  @default(now())
  reviewedAt    DateTime?

  @@unique([userId, companyId, status])
  @@index([userId])
  @@index([companyId])
}

model Job {
  id               String          @id @default(cuid())
  companyId        String
  title            String
  slug             String          @unique // e.g. "senior-react-dev-at-google"
  description      String          @db.Text
  requirements     String?         @db.Text
  responsibilities String?         @db.Text
  benefits         String?         @db.Text
  location         String
  isRemote         Boolean         @default(false)
  type             JobType         @default(FULL_TIME)
  level            ExperienceLevel @default(MID)
  category         JobCategory     @default(ENGINEERING)
  skills           String[] // ["React", "TypeScript"]
  salaryMin        Int?
  salaryMax        Int?
  salaryCurrency   String          @default("USD")
  status           JobStatus       @default(DRAFT)
  expiresAt        DateTime?
  viewCount        Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Relations
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
  savedBy      SavedJob[]

  @@index([companyId])
  @@index([status])
  @@index([category])
  @@index([type])
  @@index([level])
  @@index([isRemote])
  @@index([createdAt])
  // Composite index for common filter combo
  @@index([status, category, type, level])
}

// ============================================
// APPLICATIONS
// ============================================

model Application {
  id          String            @id @default(cuid())
  jobId       String
  candidateId String // refers to CandidateProfile.id
  coverLetter String?           @db.Text
  status      ApplicationStatus @default(PENDING)
  note        String?           @db.Text // employer's internal note
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  job       Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  // One application per job per candidate
  @@unique([jobId, candidateId])
  @@index([jobId])
  @@index([candidateId])
  @@index([status])
}

// ============================================
// SAVED JOBS
// ============================================

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
